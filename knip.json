{
  "$schema": "https://knip.dev/reference/knip-json",
  "ignoreDependencies": [
    "tailwindcss"
  ],
  "workspaces": {
    "apps/eclair": {
      "entry": [
        "src/main.tsx"
      ],
      "project": [
        "src/**/*.ts",
        "src/**/*.tsx"
      ]
    },
    "apps/docs": {
      "project": [
        ".vitepress/**/*.ts",
        ".vitepress/**/*.vue"
      ]
    },
    "packages/riviere-cli": {
      "entry": [
        "src/shell/bin.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/*": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "tools/dev-workflow-v2": {
      "entry": [
        "src/shell/cli.ts"
      ],
      "project": [
        "src/**/*.ts"
      ],
      "ignoreDependencies": [
        "@types/better-sqlite3"
      ]
    },
    "tools/dev-workflow": {
      "entry": [
        "features/complete-task/entrypoint/cli.ts",
        "features/get-pr-feedback/entrypoint/cli.ts",
        "features/respond-to-feedback/entrypoint/cli.ts",
        "features/merge-and-cleanup/entrypoint/cli.ts",
        "features/push-reflection/entrypoint/cli.ts",
        "features/claude-hooks/entrypoint/hook-router.ts"
      ],
      "project": [
        "**/*.ts"
      ]
    }
  },
  "ignore": [
    "**/node_modules/**",
    "**/*.d.ts",
    "**/dist/**",
    "**/.vitepress/dist/**",
    "**/coverage/**"
  ]
}
