{
  "permissions": {
    "deny": [
      "Edit(./tsconfig.base.json)",
      "Edit(./tsconfig.json)",
      "Edit(./nx.json)",
      "Edit(./.husky/*)",     
      "Edit(./pnpm-workspace.yaml)",
      "Edit(./.gitignore)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./apps/**/.env)",
      "Read(./apps/**/.env.*)",
      "Read(./packages/**/.env)",
      "Read(./packages/**/.env.*)"
    ]
  },
  "ask": [
    "Edit(./eslint.config.mjs)",
    "Write(./.dependency-cruiser.mjs)",
    "Write(./.dependency-cruiser.frontend.mjs)",
    "Edit(./.dependency-cruiser.mjs)",
    "Edit(./.dependency-cruiser.frontend.mjs)",
    "Write(./eslint.config.mjs)"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/dev-workflow/node_modules/.bin/tsx $CLAUDE_PROJECT_DIR/tools/dev-workflow/features/claude-hooks/entrypoint/hook-router.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/tools/dev-workflow/node_modules/.bin/tsx $CLAUDE_PROJECT_DIR/tools/dev-workflow/features/claude-hooks/entrypoint/hook-router.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "You are checking if Claude has completed its workflow obligation. When working on a GitHub issue, Claude MUST create a PR via /complete-task before stopping.\n\nRespond with {\"ok\": true} if ANY of these apply:\n- Claude is asking the user a question or waiting for clarification\n- Claude is not working on a GitHub issue\n- Claude has created a PR and is asking the user to review it\n- Claude is explicitly blocked and needs user input\n\nRespond with {\"ok\": false, \"reason\": \"→ run /complete-task to create a PR before stopping\"} ONLY if Claude appears to have finished implementing code changes on a GitHub issue without creating a PR."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "task-check@claude-skillz": true,
    "development-skills@claude-skillz": true,
    "full-codebase-review@claude-skillz": true,
    "architect-refine-critique@claude-skillz": true
  },
  "automaticCodeReview": {
    "enabled": false,
    "fileExtensions": [
      "ts",
      "tsx"
    ],
    "rulesFile": ".claude/automatic-code-review/rules.md"
  }
}
