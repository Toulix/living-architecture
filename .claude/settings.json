{
  "permissions": {
    "deny": [
      "Edit(./tsconfig.base.json)",
      "Edit(./tsconfig.json)",
      "Edit(./nx.json)",
      "Edit(./.husky/*)",
      "Edit(./pnpm-workspace.yaml)",
      "Edit(./.gitignore)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./apps/**/.env)",
      "Read(./apps/**/.env.*)",
      "Read(./packages/**/.env)",
      "Read(./packages/**/.env.*)"
    ],
    "additionalDirectories": [
      "./tools/dev-workflow-v2"
    ]
  },
  "enabledPlugins": {
    "task-check@claude-skillz": true,
    "development-skills@claude-skillz": true,
    "full-codebase-review@claude-skillz": true,
    "architect-refine-critique@claude-skillz": true,
    "dev-workflow-v2@dev-workflow-v2-marketplace": true
  },
  "ask": [
    "Edit(./eslint.config.mjs)",
    "Write(./.dependency-cruiser.mjs)",
    "Write(./.dependency-cruiser.frontend.mjs)",
    "Edit(./.dependency-cruiser.mjs)",
    "Edit(./.dependency-cruiser.frontend.mjs)",
    "Write(./eslint.config.mjs)"
  ],
  "automaticCodeReview": {
    "enabled": false,
    "fileExtensions": [
      "ts",
      "tsx"
    ],
    "rulesFile": ".claude/automatic-code-review/rules.md"
  }
}
